<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MqttClient" parent="Base.Theme.MqttClient">
        <item name="textAppearanceBody1">@style/TextAppearance.Material3.BodyMedium</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Material3.BodySmall</item>
        <item name="chipStyle">@style/Widget.Material3.Chip.Filter</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Material3.MaterialAlertDialog</item>
    </style>

    <!-- Base application theme. -->
    <style name="Base.Theme.MqttClient" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:textAppearance">@style/TextAppearance.Material3.BodyMedium</item>

        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorError">@color/error</item>

        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnError">@color/white</item>

        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.MQTTClient.AlertDialog</item>
        <item name="searchViewStyle">@style/ThemeOverlay.MQTTClient.SearchView</item>
    </style>

    <style name="ThemeOverlay.MQTTClient.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="android:background">@color/surface</item>
        <item name="android:windowBackground">@color/surface</item>

        <!-- Цвета для полей ввода -->
        <item name="android:textColorHint">@color/text_primary</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:editTextColor">@color/text_primary</item>
        <item name="colorControlActivated">@color/primary</item>
        <item name="colorControlNormal">@color/control_normal</item>

        <!-- Для списков внутри диалога -->
        <item name="android:listDivider">@color/outline</item>
    </style>

    <style name="ThemeOverlay.MQTTClient.SearchView" parent="Widget.AppCompat.SearchView">
        <item name="android:background">@color/surface</item>
        <item name="android:textColorHint">@color/text_primary</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:editTextColor">@color/text_primary</item>
        <item name="android:searchIcon">@drawable/ic_search</item>
        <item name="colorControlActivated">@color/primary</item>
    </style>
</resources>